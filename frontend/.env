# ==================================
# Frontend environment (Vite)
# ==================================
# Modo activo:
# - true  => usa configuración de producción
# - false => usa configuración de desarrollo local
VITE_USE_PROD=true

# ==================================
# PRODUCCIÓN (despliegue en servidor)
# ==================================
# Opción legacy / bandera adicional (si aplica):
# VITE_USE_DIRECT_PROD=false

# QA (referencia):
# VITE_API_BASE_PROD=https://qaerp.ardabytec.vip/api
# VITE_API_URL=https://qaerp.ardabytec.vip/api
# VITE_API_BASE_URL=https://qaerp.ardabytec.vip
# VITE_SOCKET_URL=https://qaerp.ardabytec.vip

# Producción directa (ACTUAL):
VITE_API_BASE_PROD_DIRECT=https://erp.ardabytec.vip/api
VITE_API_URL_PROD_DIRECT=https://erp.ardabytec.vip/api
VITE_API_BASE_URL_PROD_DIRECT=https://erp.ardabytec.vip
VITE_SOCKET_URL_PROD_DIRECT=https://erp.ardabytec.vip

# ==================================
# DESARROLLO LOCAL
# ==================================
# Para activar local:
# 1) Cambia VITE_USE_PROD=false
# 2) Usa estas variables
# VITE_USE_PROD=false
# VITE_USE_DIRECT_PROD=false
# VITE_API_BASE_DEV=http://localhost:5000/api
# VITE_API_URL=http://localhost:5000/api
# VITE_API_BASE_URL=http://localhost:5000

