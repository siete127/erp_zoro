# Variables de entorno para el backend ERP
# Copia este archivo a `.env` y rellena tus valores reales.

# === Facturama ===
# URL base del API de Facturama.
# Para PRUEBAS usar el sandbox:
#   https://apisandbox.facturama.mx
# Para PRODUCCIÓN solo cambia FACTURAMA_BASE_URL / USER / PASSWORD
FACTURAMA_BASE_URL=https://apisandbox.facturama.mx
FACTURAMA_USER=CALI26
FACTURAMA_PASSWORD=Bienvenido1

# Opcionales (puedes dejarlos así por defecto)
# FACTURAMA_EXPEDITION_PLACE=64000
# FACTURAMA_RECEPTOR_ZIP=64000
# FACTURAMA_RECEPTOR_REGIMEN=616

# === Email para aprobación de cambios de precio ===
EMAIL_APROBACION_PRECIOS=renteria27lr@gmail.com

