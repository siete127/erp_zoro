ERP_APP_NAME=ERP Zoro Python
ERP_API_PREFIX=/api
ERP_SQLSERVER_HOST=your-sql-server-host-or-ip
ERP_SQLSERVER_PORT=1433
ERP_SQLSERVER_DATABASE=ERP
ERP_SQLSERVER_TARGET_DATABASE=ERP_Zoro
ERP_SQLSERVER_USER=sa
ERP_SQLSERVER_PASSWORD=your-secure-password-here
ERP_SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
ERP_SQLSERVER_ENCRYPT=no
ERP_SQLSERVER_TRUST_SERVER_CERTIFICATE=yes
ERP_SECRET_KEY=your-secret-key-min-32-characters
ERP_ACCESS_TOKEN_EXPIRE_HOURS=8
ERP_FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
EMAIL_APROBACION_PRECIOS=your-approval-email@example.com
FACTURAMA_BASE_URL=https://api.facturama.mx
FACTURAMA_USER=your-facturama-user
FACTURAMA_PASSWORD=your-facturama-password
FACTURAMA_USER_COMPANY_1=your-facturama-company-1
FACTURAMA_PASSWORD_COMPANY_1=your-facturama-password-1
FACTURAMA_USER_COMPANY_3=your-facturama-company-3
FACTURAMA_PASSWORD_COMPANY_3=your-facturama-password-3
