# ============================================================
# .env.production — copiar a .env en el servidor de producción
# NUNCA subir este archivo con valores reales al repositorio
# ============================================================

ERP_APP_NAME=ERP Zoro
ERP_API_PREFIX=/api
ERP_ENVIRONMENT=production

# Base de datos SQL Server
ERP_SQLSERVER_HOST=your-prod-sql-server-ip
ERP_SQLSERVER_PORT=1433
ERP_SQLSERVER_DATABASE=ERP
ERP_SQLSERVER_TARGET_DATABASE=ERP_Zoro
ERP_SQLSERVER_USER=erp_user
ERP_SQLSERVER_PASSWORD=CHANGE_ME_strong_password_here
ERP_SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
ERP_SQLSERVER_ENCRYPT=yes
ERP_SQLSERVER_TRUST_SERVER_CERTIFICATE=no

# Seguridad — CAMBIAR antes de producción (mínimo 64 caracteres aleatorios)
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
ERP_SECRET_KEY=CHANGE_ME_at_least_64_random_chars_here
ERP_ACCESS_TOKEN_EXPIRE_HOURS=8

# CORS — solo el dominio real del frontend
ERP_FRONTEND_ORIGINS=https://erp.tudominio.com

# Email (Gmail App Password)
EMAIL_USER=erp@tudominio.com
EMAIL_PASSWORD=CHANGE_ME_gmail_app_password

# URLs públicas
BACKEND_URL=https://api.tudominio.com
FRONTEND_URL=https://erp.tudominio.com

# Redis (si se usa para sesiones/cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0

# Facturama (si aplica)
FACTURAMA_BASE_URL=https://api.facturama.mx
FACTURAMA_USER=CHANGE_ME
FACTURAMA_PASSWORD=CHANGE_ME
